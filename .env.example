# ─────────────────────────────────────────────────────────────────────
# v3code — required environment variables for full OAuth.
# Copy this file to `.env` and fill in real values. The .env file is
# gitignored. For Cloudflare Workers deploys, use `wrangler secret put`
# with the same key names instead.
# ─────────────────────────────────────────────────────────────────────

# ── GitHub Server-side OAuth (Web app + Cloud env chats) ─────────────
# Register at: https://github.com/settings/developers → New OAuth App
#   Application name:        v3code (or your fork name)
#   Homepage URL:            http://localhost:13773
#   Callback URL:            http://localhost:13773/api/auth/github/callback
# After creating, click "Generate a new client secret" and paste both
# values below. For prod (Cloudflare Workers), register a SECOND OAuth
# app with your Worker URL as homepage + callback.
V3CODE_GITHUB_CLIENT_ID=
V3CODE_GITHUB_CLIENT_SECRET=

# ── GitHub Public Client (Desktop Device Flow) ───────────────────────
# Optional. Register a SEPARATE OAuth app with "Enable Device Flow"
# checked at https://github.com/settings/developers. No client secret
# is needed for Device Flow.
V3CODE_GITHUB_PUBLIC_CLIENT_ID=

# ── Google OAuth ─────────────────────────────────────────────────────
# Register at: https://console.cloud.google.com/apis/credentials
#   Application type:        Web application
#   Authorized redirect URI: http://localhost:13773/api/auth/google/callback
# After creating, copy the Client ID + Client secret here. For prod,
# add your Worker URL as a second authorized redirect URI on the
# SAME credential.
V3CODE_GOOGLE_CLIENT_ID=
V3CODE_GOOGLE_CLIENT_SECRET=

# ── Email allowlist (comma-separated) ────────────────────────────────
# Restricts who can bootstrap an account. Single line, values separated
# by commas (no newlines). Leave blank in dev.
V3CODE_AUTHORIZED_EMAILS=

# ── Token encryption key (server-side at-rest) ───────────────────────
# Generate with: openssl rand -base64 32
# Required for storing GitHub access tokens encrypted in the DB.
V3CODE_TOKEN_ENCRYPTION_KEY=

# ── Optional: trust X-Forwarded-For for rate-limit attribution ───────
# Set to `1` ONLY if v3code is reachable through a reverse proxy you
# control that strips client-supplied X-Forwarded-For headers and
# appends a trusted one. When unset (default), the rate limiter keys
# off the socket peer address so spoofed XFF cannot bypass throttling.
# V3CODE_TRUST_FORWARDED_FOR=1

# ── Optional: server public URL ──────────────────────────────────────
# Used to build OAuth redirect URIs when the server is behind a tunnel
# or load balancer. If unset, the server uses the request's Host header.
# V3CODE_SERVER_PUBLIC_URL=https://v3code.example.com

# ── Optional: server port + host ─────────────────────────────────────
# V3CODE_PORT=13773
# HOST=127.0.0.1
